    "db:seed:remote": "wrangler d1 execute xiaoheishu-db --remote --file=seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250422.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  }
}
