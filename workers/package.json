{
  "name": "xiaoheishu-workers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute xiaoheishu-db --file=schema.sql",
    "db:seed": "wrangler d1 execute xiaoheishu-db --file=seed.sql",
